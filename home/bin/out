#!/usr/bin/env bash
# Usage: {script} [OPTIONS] [STRING]...
# Outputs a string, but replacing <content> to ANSI escape code. Use `--list` to show all the options.
##

# https://en.wikipedia.org/wiki/ANSI_escape_code#Select_Graphic_Rendition_parameters
declare -A GRAPHIC_RENDITIONS=(
    ['bold']=1
    ['faint']=2
    ['italic']=3
    ['underline']=4
    ['invert']=7
    ['strike']=9
    ['doubly_underlined']=21
)

# https://en.wikipedia.org/wiki/ANSI_escape_code#Colors
declare -A FOREGROUND_COLORS=(
    ['black']=30
    ['red']=31
    ['green']=32
    ['yellow']=33
    ['blue']=34
    ['purple']=35
    ['cyan']=36
    ['white']=37
    ['bright_black']=90
    ['bright_red']=91
    ['bright_green']=92
    ['bright_yellow']=93
    ['bright_blue']=94
    ['bright_purple']=95
    ['bright_cyan']=96
    ['bright_white']=97
)

declare -A BACKGROUND_COLORS=(
    ['black']=40
    ['red']=41
    ['green']=42
    ['yellow']=43
    ['blue']=44
    ['purple']=45
    ['cyan']=46
    ['white']=47
    ['bright_black']=100
    ['bright_red']=101
    ['bright_green']=102
    ['bright_yellow']=103
    ['bright_blue']=104
    ['bright_purple']=105
    ['bright_cyan']=106
    ['bright_white']=107
)

out() {
    local content="${@}"

    # Handle named and HEX colors/renditions: <g:bold>, <f:red>, <b:bright_cyan>, <f:#00FF77>, etc.
    # 38 = set foreground to 24-bit RGB, 48 = set background to 24-bit RGB
    local -A HEX_BASE=(['f']=38 ['b']=48)
    local pattern='<(g|f|b):([a-z_]+|#[0-9A-Fa-f]{6})>'
    while [[ $content =~ $pattern ]]; do
        local match="${BASH_REMATCH[0]}"
        local type="${BASH_REMATCH[1]}"
        local value="${BASH_REMATCH[2]}"
        if [[ "$value" == '#'* ]]; then
            local hex="${value#'#'}"
            local r=$((16#${hex:0:2}))
            local g=$((16#${hex:2:2}))
            local b=$((16#${hex:4:2}))
            content="${content//${match}/\\e[${HEX_BASE[$type]};2;${r};${g};${b}m}"
        else
            local code
            case "$type" in
                g) code=${GRAPHIC_RENDITIONS[$value]} ;;
                f) code=${FOREGROUND_COLORS[$value]} ;;
                b) code=${BACKGROUND_COLORS[$value]} ;;
            esac
            content="${content//${match}/\\e[${code}m}"
        fi
    done

    content=${content//<\/>/\\e[m}

    content+="\033[m"

    echo -e $(sed -E 's,<([0-9;]+)?>,\\e[\1m,g' <<< "${content}")
}

declare IFS=$'\n'

if [[ "${1}" == "--help" ]] || [[ "${1}" == "-h" ]]; then
    script-help "${0}"
    exit
fi

word() {
    shuf -n 1 /usr/share/dict/words
}

if [[ "${1}" == "--list" ]] || [[ "${1}" == "-l" ]]; then
    printf "Graphic renditions\n\n"
    for name in $(sort <<< "${!GRAPHIC_RENDITIONS[@]}"); do
        code=${GRAPHIC_RENDITIONS[$name]}
        printf "  %-24s Code: %-14s e.g. %s\n" \
            "<g:${name}>" ${code} "$(out "<g:${name}><g:${name}>$(word)</>")"
    done

    echo

    printf "Foreground colors\n\n"
    for name in $(sort <<< "${!FOREGROUND_COLORS[@]}"); do
        code=${FOREGROUND_COLORS[$name]}
        printf "  %-24s Code: %-14s e.g. %s\n" \
            "<f:${name}>" ${code} "$(out "<f:${name}>$(word)</>")"
    done

    echo

    printf "Background colors\n\n"
    for name in $(sort <<< "${!BACKGROUND_COLORS[@]}"); do
        code=${BACKGROUND_COLORS[$name]}
        printf "  %-24s Code: %-14s e.g. %s\n" \
            "<b:${name}>" ${code} "$(out "<b:${name}>$(word)</>")"
    done

    echo

    printf "HEX colors\n\n"
    printf "  %-24s 24-bit foreground    e.g. %s\n" "<f:#RRGGBB>" "$(out "<f:#CC0000>f:#CC0000</>")"
    printf "  %-24s 24-bit background    e.g. %s\n" "<b:#RRGGBB>" "$(out "<b:#CCFFCC>b:#CCFFCC</>")"
    exit
fi

out "${@}"
