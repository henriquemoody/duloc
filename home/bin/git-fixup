#!/usr/bin/env bash
# Usage: {script} [OPTIONS] [PATH]...
# Construct a commit message for use with rebase --autosquash.
#
# The commit message will be the subject line from the specified commit with a
# prefix of "fixup! " and will contain the staged changes.
#
# Uses fzf for interactive commit selection.
#
#   --help, -h   Displays this help
#
# Report bugs to Henrique Moody <henriquemoody@gmail.com>
#

set -eo pipefail

help()
{
  sed -E 's/^#\s?(.*)/\1/g' "${0}" |
    sed -nE '/^Usage/,/^Report/p' |
    sed "s/{script}/$(basename "${0}")/g"
}

git-log()
{
  local -r format=$'%h\t%s'
  local -r number_of_commits=15

  git log origin/HEAD..HEAD --format="${format}" "${@}" 2>/dev/null ||
    git log --max-count "${number_of_commits}" --format="${format}" "${@}"
}

if [[ "${1:-}" = "--help" ]] || [[ "${1:-}" = "-h" ]]; then
  help
  exit
fi

declare input=""
while IFS=$'\t' read -r hash subject; do
  [[ "${subject}" =~ ^fixup! ]] && continue
  input+="${hash}"$'\t'"$(out "<f:yellow>${hash}</> ${subject}")"$'\n'
done < <(git-log "${@}" | tac)

if [[ -z "${input}" ]]; then
  out "<f:red>No commits available to fixup.</>" >&2
  exit 1
fi

declare selected=""
selected=$(printf '%s' "${input}" | \
  fzf --ansi \
      --delimiter=$'\t' \
      --with-nth=2 \
      --prompt="$(out '<f:cyan>fixup</> ▶ ') " \
      --header="$(out '<g:bold>Select a commit to fixup</>')" \
      --preview='git show --stat --color {1}' \
      --preview-window='right:55%') || true

if [[ -z "${selected}" ]]; then
  out "<f:yellow>No commit selected, aborting.</>" >&2
  exit 1
fi

declare -r commit_hash=$(cut -f1 <<< "${selected}")

echo
git commit --fixup="${commit_hash}" "${@}"
