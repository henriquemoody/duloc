#!/usr/bin/env bash

set -euo pipefail

URL="${1:-}"
DIRECTORY="${2:-$(basename "${URL}" .git)}"

if [[ -z "${URL}" ]]; then
  echo "Usage: git bare-clone <url> [directory]" 1>&2
  exit 1
fi

DESTINATION=$(realpath "${DIRECTORY}")

echo "Cloning into bare repository '${DESTINATION}'..."
mkdir -p "${DESTINATION}"
git clone --bare "${URL}" "${DESTINATION}/.git"
cd "${DESTINATION}"

echo "Setting up Git repository..."
git config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"
git config worktree.guessRemote true

DEFAULT_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || true)
if [[ -z "${DEFAULT_BRANCH}" ]]; then
  DEFAULT_BRANCH=$(git ls-remote --symref origin HEAD | awk '/^ref:/ {sub("refs/heads/", "", $2); print $2; exit}')
fi

if [[ -z "${DEFAULT_BRANCH}" ]]; then
  echo "Could not determine the default branch." 1>&2
  exit 1
fi

echo "Creating worktree for ${DEFAULT_BRANCH}..."
git worktree add "${DEFAULT_BRANCH}" "${DEFAULT_BRANCH}"

echo "Done!"
